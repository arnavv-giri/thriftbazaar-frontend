# ============================================================
# ThriftBazaar Frontend — Environment Variable Template
# ============================================================
# Copy this file to .env (for development) or .env.production
# (for production builds) and fill in the values.
#
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Never put secrets here — these values are visible in the built JS.
# ============================================================

# Base URL of the Spring Boot API server.
# Change this to your deployed backend URL in production.
VITE_API_BASE_URL=http://localhost:8081

# Razorpay publishable key (safe to expose — it's a public identifier).
# The secret key stays ONLY in the backend application-local.properties.
# Get yours from: https://dashboard.razorpay.com → Settings → API Keys
# VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
