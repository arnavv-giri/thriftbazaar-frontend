# ============================================================
# ThriftBazaar Frontend — Environment Variable Template
# ============================================================
# Copy this file to .env (local dev) or set in Vercel dashboard
# for production.
#
# NEVER commit .env or .env.production — they are git-ignored.
# ============================================================

# Base URL of the Spring Boot API server.
# Local dev:
VITE_API_BASE_URL=http://localhost:8081
# Production (set this in Vercel env vars, not here):
# VITE_API_BASE_URL=https://your-backend.up.railway.app
